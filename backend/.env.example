# --- Database (Supabase) ---
# DATABASE_URL: pooled connection (Supavisor, port 6543) — used by the app at runtime.
# DIRECT_URL:   direct connection (port 5432) — used by `prisma migrate` only.
# Find both under: Supabase Dashboard -> Project Settings -> Database -> Connection string.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- Server ---
PORT=4000
HOST=0.0.0.0
NODE_ENV=production

# Comma-separated list of allowed browser origins (the Vercel frontend URL).
FRONTEND_ORIGIN=https://your-frontend.vercel.app

# Simulated Stripe network latency in ms (0 disables the artificial delay).
STRIPE_MOCK_LATENCY_MS=40
