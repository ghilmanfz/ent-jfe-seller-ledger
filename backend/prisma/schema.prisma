// Financial event store + double-entry ledger.
//
// Design notes (full rationale in docs/ARCHITECTURE.md and docs/FINANCIAL_RULES.md):
// - EventLog is the source of truth (append-only, enforced by DB triggers in the
//   migration). Everything else (OrderProjection, Settlement) is derivable from it.
// - All money columns are DECIMAL(18,4): exact base-10 arithmetic, 4 decimal places
//   so intermediate values (3% fees) keep sub-cent precision; 18 digits of headroom
//   covers any realistic daily volume without overflow.
// - Ledger rows are immutable double-entry postings: per event, sum(debit) always
//   equals sum(credit). A CHECK constraint (in the migration SQL) guarantees each
//   row has exactly one of debit/credit, strictly positive.
// - Unique(aggregateId, version) is the optimistic-concurrency guard: two writers
//   appending to the same order race on the same version number and exactly one wins.
// - Unique(idempotencyKey) makes every mutation replay-safe: a retry can only ever
//   find the original event, never create a second one.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum EventType {
  OrderCreated
  PaymentProcessing
  PaymentConfirmed
  PaymentFailed
  FeeCalculated
  OrderShipped
  OrderDelivered
  OrderRefunded
  SettlementProcessed
}

// Chart of accounts. The assignment names four buckets (order_balance, payment,
// fees, payout); the service-level posting rules in the brief use these five
// concrete accounts, which we follow exactly.
enum LedgerAccount {
  order_balance
  order_pending
  payment_received
  fees_owed
  seller_payout
}

enum OrderStatus {
  CREATED
  PAYMENT_PROCESSING
  PAYMENT_FAILED
  PAID
  SHIPPED
  DELIVERED
  REFUNDED
}

enum PaymentMethod {
  card
  bank_transfer
  wallet
}

model EventLog {
  id             String    @id @default(uuid()) @db.Uuid
  aggregateId    String    @map("aggregate_id")
  eventType      EventType @map("event_type")
  // Monetary values inside the payload are stored as strings ("100.0000"),
  // never JSON numbers — JSON numbers are IEEE-754 floats and would corrupt cents.
  payload        Json
  version        Int
  timestamp      DateTime  @default(now()) @db.Timestamptz(6)
  idempotencyKey String    @unique(map: "event_log_idempotency_key_key") @map("idempotency_key")

  ledgerEntries LedgerEntry[]

  // Also serves as the (aggregateId, version) index required by the brief.
  @@unique([aggregateId, version], map: "event_log_aggregate_id_version_key")
  @@index([eventType])
  @@index([timestamp])
  @@map("event_log")
}

model LedgerEntry {
  id        String        @id @default(uuid()) @db.Uuid
  orderId   String        @map("order_id")
  // Every posting points back at the exact event that caused it — the audit trail.
  eventId   String        @map("event_id") @db.Uuid
  account   LedgerAccount
  debit     Decimal?      @db.Decimal(18, 4)
  credit    Decimal?      @db.Decimal(18, 4)
  timestamp DateTime      @default(now()) @db.Timestamptz(6)

  order OrderProjection @relation(fields: [orderId], references: [id], onDelete: Restrict)
  event EventLog        @relation(fields: [eventId], references: [id], onDelete: Restrict)

  @@index([orderId, timestamp])
  @@index([eventId])
  @@index([account])
  @@map("ledger_entry")
}

// Read model. Never authoritative: rebuildable at any time by folding EventLog
// (see scripts/rebuild-projections.ts). Updated in the same transaction as the
// event append, so reads are always consistent with the event stream.
model OrderProjection {
  id             String        @id
  customerId     String        @map("customer_id")
  paymentMethod  PaymentMethod @map("payment_method")
  amount         Decimal       @db.Decimal(18, 4)
  feeAmount      Decimal?      @map("fee_amount") @db.Decimal(18, 4)
  payoutAmount   Decimal?      @map("payout_amount") @db.Decimal(18, 4)
  status         OrderStatus
  // Mirrors the version of the last event applied to this aggregate.
  version        Int
  stripeChargeId String?       @map("stripe_charge_id")
  settlementId   String?       @map("settlement_id")
  settledAt      DateTime?     @map("settled_at") @db.Timestamptz(6)
  paidAt         DateTime?     @map("paid_at") @db.Timestamptz(6)
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  ledgerEntries LedgerEntry[]
  settlement    Settlement?   @relation(fields: [settlementId], references: [id])

  @@index([status])
  @@index([settlementId])
  @@index([customerId])
  @@index([paidAt])
  @@map("order_projection")
}

// One row per settled calendar date (UTC). The date is the natural idempotency
// key: settling the same day twice must return the same result.
model Settlement {
  id          String   @id
  date        String   @unique // YYYY-MM-DD (UTC)
  orderCount  Int      @map("order_count")
  totalGross  Decimal  @map("total_gross") @db.Decimal(18, 4)
  totalFees   Decimal  @map("total_fees") @db.Decimal(18, 4)
  totalPayout Decimal  @map("total_payout") @db.Decimal(18, 4)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  orders OrderProjection[]

  @@map("settlement")
}
